# Telegram Bot
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs that are allowed to talk to this bot.
# Get your ID by messaging @userinfobot on Telegram.
ALLOWED_TELEGRAM_IDS=

# Path to the Obsidian vault this bot uses as its brain.
# One vault per bot. Must exist and be writable.
HIPPO_VAULT_PATH=

# Bot identity. Used for inter-bot mailbox routing (Phase 3)
# and as a prefix in log messages.
HIPPO_BOT_NAME=alice

# Optional: override the default model.
# Defaults to claude-sonnet-4-5. Auth via `claude login` on the server.
# HIPPO_MODEL=claude-sonnet-4-5
