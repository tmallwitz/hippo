# =============================================================
# Hippo Multi-Bot Configuration
# =============================================================
# Each bot reads env vars with its NAME as a prefix (uppercased).
# Example: bot "Alice" (started with `uv run hippo Alice`) reads
# ALICE_TELEGRAM_BOT_TOKEN, ALICE_ALLOWED_TELEGRAM_IDS, etc.
#
# Unprefixed HIPPO_* vars are shared defaults that apply to all
# bots unless overridden with a per-bot prefix.
#
# Start a bot:   uv run hippo Alice
# Start another: uv run hippo Bob  (in a separate terminal)
#
# Migration from single-bot setup: add `Alice` as the bot name
# argument — your existing unprefixed vars still work as fallback.
# =============================================================


# --- Shared defaults (apply to all bots unless overridden) ---

# Claude model used by all bots. Auth via `claude login`.
# HIPPO_MODEL=claude-sonnet-4-5

# Model used for the dream consolidation sub-agent.
# HIPPO_DREAM_MODEL=claude-sonnet-4-5

# Timezone for the scheduler (IANA identifier).
HIPPO_TIMEZONE=Europe/Berlin

# Number of buffer entries that trigger an automatic dream cycle.
# HIPPO_BUFFER_MAX_ENTRIES=50

# Whisper model size for local voice transcription.
# Options: tiny, base, small, medium, large (larger = slower but more accurate)
# Requires ffmpeg installed on the host.
# HIPPO_WHISPER_MODEL=small

# Language hint for Whisper. Skips auto-detection and significantly improves
# accuracy for non-English speech. Use ISO 639-1 codes: de, en, fr, es, …
# Leave unset to let Whisper auto-detect the language.
# HIPPO_WHISPER_LANGUAGE=de

# Local embedding model for semantic search (sentence-transformers model ID).
# First use downloads ~80MB. Set to empty string to disable embeddings and
# fall back to substring matching.
# HIPPO_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cosine similarity threshold for semantic search (0.0–1.0, default 0.4).
# Lower = more results, higher = stricter matching.
# HIPPO_SEARCH_THRESHOLD=0.4

# Age in days after which large episodic daily notes are summarized during
# the dream cycle. Originals are archived to episodic/archive/.
# HIPPO_EPISODIC_ARCHIVE_DAYS=30

# Retention period in days for processed files cleaned up during the dream
# housekeeping step. Episodic archive dailies are consolidated into monthly
# files instead of deleted.
# HIPPO_RETENTION_DAYS=90


# --- Bot: Alice (uv run hippo Alice) ---

# Create a bot via @BotFather on Telegram and paste the token here.
ALICE_TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to talk to this bot.
# Get your ID by messaging @userinfobot on Telegram.
ALICE_ALLOWED_TELEGRAM_IDS=

# Path to the Obsidian vault this bot uses as its brain.
# One vault per bot. Must exist and be writable.
ALICE_HIPPO_VAULT_PATH=

# Per-bot model override (optional):
# ALICE_HIPPO_MODEL=claude-opus-4-6


# --- Bot: Bob (uv run hippo Bob) — uncomment to add a second bot ---

# BOB_TELEGRAM_BOT_TOKEN=
# BOB_ALLOWED_TELEGRAM_IDS=
# BOB_HIPPO_VAULT_PATH=
